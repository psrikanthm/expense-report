# Personal Finance CLI - Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control

# LLM Configuration (defaults to LM Studio local server)
# For OpenAI, set LLM_BASE_URL=https://api.openai.com/v1 and LLM_API_KEY=sk-...
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio

# Google Maps API key for LLM-based categorization with MCP tools
# Optional: If not set, categorization will work without location-aware search
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AWS SES SMTP Credentials (for email notifications)
SES_SMTP_USERNAME=your_ses_smtp_username
SES_SMTP_PASSWORD=your_ses_smtp_password
SES_FROM_EMAIL=your_sender_email@example.com

# Email recipients (comma-separated, can include names)
# Example: "Name One <email1@example.com>, Name Two <email2@example.com>"
REPORT_RECIPIENTS=recipient1@example.com, recipient2@example.com

# Optional: Override default SES settings
# SES_SMTP_SERVER=email-smtp.us-east-1.amazonaws.com
# SES_SMTP_PORT=465
